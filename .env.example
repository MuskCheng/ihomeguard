# ========================================
#  iHomeGuard 环境变量配置
# ========================================
#
# 🔒 安全建议：
#   请勿使用管理员账户！建议在爱快路由器中创建一个【只读账户】用于数据采集。
#   创建步骤：
#   1. 登录爱快路由器管理后台
#   2. 进入【系统设置】→【账户管理】
#   3. 点击【添加账户】
#   4. 设置用户名和密码
#   5. 权限选择：只读权限
#   6. 保存后使用此账户信息配置下方变量
#
# ========================================

# 爱快路由器配置（必填）
IKUAI_URL=http://192.168.1.1
IKUAI_USER=monitor          # 只读账户用户名
IKUAI_PASS=your_password    # 只读账户密码

# PushMe 推送配置（必填）
PUSHME_KEY=your_pushme_key  # 在 PushMe App 中获取

# Web 端口（可选，默认 8680）
WEB_PORT=8680